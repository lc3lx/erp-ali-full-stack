NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/container_db?schema=public
JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=7d
# Production: comma-separated origins are supported, e.g.
# CORS_ORIGIN=https://alipride.com,https://www.alipride.com,http://alipride.com,http://www.alipride.com
CORS_ORIGIN=http://localhost:5173
ENABLE_SWAGGER=true
