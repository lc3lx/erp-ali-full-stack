# هيكل المشروع: container-app/ (فرونت Vite) + container-app/backend/ (API)
#
# التطوير (npm run dev): اترك VITE_API_BASE فارغاً — Vite يوجّه /api و /health إلى localhost:4000
#
# الإنتاج: ابنِ الفرونت مع عنوان الباك اند (نفس المنفذ 443/80 أو نطاق API)، مثلاً:
#   Windows CMD:  set VITE_API_BASE=https://api.example.com&& npm run build
#   PowerShell:     $env:VITE_API_BASE="https://api.example.com"; npm run build
# ثم اعرض مجلد dist/static على أي استضافة؛ تأكد أن الباك اند يضبط CORS_ORIGIN لنطاق الواجهة.

VITE_API_BASE=
